{
  "name": "bolt-downloader",
  "version": "1.0.0",
  "description": "A fast and lightweight desktop download manager built with Electron and SQLite",
  "main": "main.js",
  "author": {
    "name": "randomdev",
    "email": "149841624+pabloacisera@users.noreply.github.com"
  },
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "nodemon --exec electron .",
    "publish": "electron-builder --publish always"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "sweetalert2": "^11.26.24"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.14"
  },
  "build": {
    "appId": "com.pabloacisera.boltyt",
    "productName": "Bolt Downloader",
    "directories": {
      "output": "dist",
      "buildResources": "icons"
    },
    "win": {
      "target": "nsis",
      "icon": "icons/icono-app.ico"
    },
    "linux": {
      "target": "deb",
      "category": "Utility",
      "icon": "icons/icono-app.png",
      "maintainer": "randomdev <randomdev@users.noreply.github.com>"
    },
    "files": [
      "**/*",
      "!dist",
      "!.github",
      "!node_modules/electron"
    ]
  }
}